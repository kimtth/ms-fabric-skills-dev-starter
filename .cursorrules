# Microsoft Fabric Development Rules for Cursor

# Read .agents/instructions.md for full agent guidance.
# Skills are in .agents/skills/.

# Architecture: Agents -> Skills -> Common
# Delegate endpoint-specific depth to .agents/skills/.

# Authentication
# All Fabric REST calls require Entra ID bearer tokens.
# az login && az account get-access-token --resource https://api.fabric.microsoft.com

# Code Rules
# - Delta Lake format for all Lakehouse tables
# - Parameterize workspace ID, item ID, token audience
# - Handle pagination (continuationToken), LRO (Retry-After), throttling (429)
# - Use notebookutils in Fabric notebooks; preserve mssparkutils only for existing backward-compatible code
# - Never hardcode secrets

# Reference
# Fabric REST APIs: https://learn.microsoft.com/en-us/rest/api/fabric/articles/
# Fabric docs: https://learn.microsoft.com/en-us/fabric/

rules:
  - name: delta_lake_format
    description: Always use Delta Lake format for Lakehouse tables
    pattern: "spark.write.format(\"delta\")"

  - name: correct_auth_scope
    description: Use correct token audience per workload (see .agents/skills/fabric-core/SKILL.md)

  - name: pagination_required
    description: All list APIs must handle continuationToken pagination

  - name: lro_handling
    description: Mutating operations may return 202 — implement LRO polling with Retry-After

  - name: no_hardcoded_secrets
    description: Never hardcode credentials — use Key Vault or environment variables
    forbidden_patterns:
      - "password="
      - "secret="
      - "connectionstring="

  - name: notebookutils_usage
    description: Use notebookutils for Fabric-specific operations in notebooks; preserve mssparkutils only for existing backward-compatible code
    applies_to: ["*.py", "*.ipynb"]

  - name: parameterize_ids
    description: Never hardcode workspace or item IDs — use variables or config

documentation_links:
  fabric_rest_api: https://learn.microsoft.com/en-us/rest/api/fabric/articles/
  lakehouse: https://learn.microsoft.com/en-us/fabric/data-engineering/lakehouse-overview
  warehouse: https://learn.microsoft.com/en-us/fabric/data-warehouse/data-warehousing
  notebooks: https://learn.microsoft.com/en-us/fabric/data-engineering/how-to-use-notebook
  pipelines: https://learn.microsoft.com/en-us/fabric/data-factory/data-factory-overview
  kql: https://learn.microsoft.com/en-us/fabric/real-time-intelligence/create-database
  semantic_models: https://learn.microsoft.com/en-us/power-bi/connect-data/service-datasets-understand
